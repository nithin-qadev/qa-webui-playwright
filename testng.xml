<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="CrossBrowserSuite" parallel="tests">

    <test name="Chromium Tests">
        <parameter name="browser" value="chromium"/>
        <classes>
            <class name="com.internetheroku.tests.LoginTest"/>
        </classes>
    </test>

    <test name="WebKit (Safari) Tests">
        <parameter name="browser" value="webkit"/>
        <classes>
            <class name="src.internetheroku.tests.LoginTest"/>
        </classes>
    </test>

</suite>